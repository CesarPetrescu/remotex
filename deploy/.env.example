# Copy this to .env and fill in before `docker compose --profile tls up -d`.
# Without the tls profile, only the relay runs on 127.0.0.1:8080.

# Public hostname for the Caddy vhost (required for real TLS certs).
REMOTEX_HOSTNAME=relay.example.com

# Email passed to Let's Encrypt via Caddy for renewal notices.
ACME_EMAIL=you@example.com

# Optional: container timezone.
# TZ=Europe/Bucharest
# Keep daemon sessions alive this long after a web/mobile socket drops,
# so phone sleep, network switches, or browser reloads can reconnect.
# RELAY_CLIENT_RECONNECT_GRACE_SECONDS=75

# Override the host port if :8080 is already taken on your box.
# RELAY_HOST_PORT=18080
# RELAY_HOST_BIND=0.0.0.0    # bind to all interfaces instead of loopback

# Postgres inventory store (users/hosts/sessions). The defaults match the
# bundled postgres service; only override if you change them there too.
# POSTGRES_DB=remotex
# POSTGRES_USER=remotex
# POSTGRES_PASSWORD=change-me
