# Copy this to .env and fill in before `docker compose --profile tls up -d`.
# Without the tls profile, only the relay runs on 127.0.0.1:8080.

# Public hostname for the Caddy vhost (required for real TLS certs).
REMOTEX_HOSTNAME=relay.example.com

# Email passed to Let's Encrypt via Caddy for renewal notices.
ACME_EMAIL=you@example.com

# Optional: container timezone.
# TZ=Europe/Bucharest
# Keep daemon sessions alive this long after a web/mobile socket drops,
# so phone sleep, network switches, or browser reloads can reconnect.
# RELAY_CLIENT_RECONNECT_GRACE_SECONDS=75

# Override the host port if :8080 is already taken on your box.
# RELAY_HOST_PORT=18080
# RELAY_HOST_BIND=0.0.0.0    # bind to all interfaces instead of loopback

# Semantic chat search. The relay stores vectors in the bundled
# pgvector Postgres service. Set the embedding endpoint/key to enable
# searchable results.
# SEARCH_POSTGRES_DB=remotex
# SEARCH_POSTGRES_USER=remotex
# SEARCH_POSTGRES_PASSWORD=change-me
# EMBEDDING_API_BASE_URL=http://your-litellm-host:80/v1
# EMBEDDING_API_KEY=your-litellm-master-key
# EMBEDDING_MODEL=qwen3-embedding
# EMBEDDING_DIMENSIONS=4096
# EMBEDDING_MAX_CONTEXT_TOKENS=32768
# EMBEDDING_BATCH_SIZE=16
# SEARCH_CHUNK_MAX_TOKENS=512    # target vector granularity (64-8192)
# SEARCH_CHUNK_MIN_TOKENS=8      # drop chunks shorter than this
# Cross-encoder rerank. Defaults to the same LiteLLM endpoint that serves
# EMBEDDING_API_BASE_URL; override here if the reranker lives elsewhere.
# RERANKER_API_BASE_URL=http://your-litellm-host:80/v1
# RERANKER_API_KEY=your-litellm-master-key
# RERANKER_MODEL=qwen3-reranker
# SEARCH_RERANK_POOL=50          # candidates sent to the reranker
# SEARCH_RERANK_TOP_N=20         # how many the reranker keeps

# Chat title/description generation through the LiteLLM LLM endpoint.
# Defaults to the embedding endpoint/key when MAIN_MODEL_* is unset.
# MAIN_MODEL_API_BASE_URL=http://your-litellm-host:80/v1
# MAIN_MODEL_API_KEY=your-litellm-master-key
# MAIN_MODEL=MainModel
# MAIN_MODEL_CONTEXT_TOKENS=16000
# MAIN_MODEL_DISABLE_THINKING_STYLE=chat_template_kwargs
# CHAT_TITLE_ENABLED=1
# CHAT_TITLE_MAX_INPUT_TOKENS=12000
# CHAT_TITLE_MAX_ATTEMPTS=3
